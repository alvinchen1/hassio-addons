#!/usr/bin/env bash
set -e

LOG_LEVEL="${LOG_LEVEL:-INFO}"
MQTT_HOST="${MQTT_HOST:-127.0.0.1}"
MQTT_TOPIC="${MQTT_TOPIC:-garage/subaru/homelink_button}"
FREQ_RANGE="${FREQ_RANGE:-315M:316M:5k}"
THRESHOLD_DB="${THRESHOLD_DB:-20}"

log() {
  local level="$1"; shift
  echo "[homelink] ${level} $*"
}

log INFO "Starting HomeLink detector on ${FREQ_RANGE}, threshold ${THRESHOLD_DB} dB"

rtl_power -f "${FREQ_RANGE}" -i 1 -g 40 - | while read -r line; do
    if [[ -z "$line" ]] || [[ "$line" =~ ^# ]]; then
        continue
    fi

    MAX_DB=$(echo "$line" | awk '{max=$6; for(i=7;i<=NF;i++){if($i>max)max=$i} print max}')
    if [[ -z "$MAX_DB" ]]; then
        continue
    fi

    if (( $(echo "$MAX_DB > $THRESHOLD_DB" | bc -l) )); then
        log INFO "RF spike: ${MAX_DB} dB — publishing MQTT"
        mosquitto_pub -h "${MQTT_HOST}" -t "${MQTT_TOPIC}" -m "pressed"
        sleep 1
    else
        log DEBUG "Noise: ${MAX_DB} dB"
    fi
done