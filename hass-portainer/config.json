{
  "name": "Portainer",
  "slug": "portainer",
  "version": "2026.2.1",
  "description": "Container management made easy",
  "url": "https://github.com/alvinchen1/hassio-addons",

  "arch": [
    "amd64",
    "armv7",
    "armhf",
    "aarch64"
  ],

  "startup": "services",
  "init": false,
  "docker_api": true,

  "ingress": true,
  "ingress_port": 9000,
  "panel_icon": "mdi:docker",

  "image": "mikejmcguire/hass-portainer-{arch}",

  "ports": {
    "8000/tcp": null,
    "9000/tcp": null,
    "9443/tcp": null
  },

  "ports_description": {
    "8000/tcp": "Port for exposing Portainer to edge agents",
    "9000/tcp": "Port for exposing Portainer UI directly",
    "9443/tcp": "Port for exposing Portainer UI directly (HTTPS)"
  },

  "map": [
    "ssl"
  ]
}